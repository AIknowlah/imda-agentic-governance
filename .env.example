# =============================================================================
# .env.example — Environment Variable Template
# =============================================================================
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it is protected by .gitignore.
#
# Setup steps:
#   1. cp .env.example .env          (Mac/Linux)
#      copy .env.example .env        (Windows)
#   2. Edit .env and replace the placeholder below with your real API key
#   3. Get your key at: https://aistudio.google.com
#
# =============================================================================

GOOGLE_API_KEY=your_google_api_key_here
